{% extends "../partials/layout.njk" %}
{%- from "moj/components/alert/macro.njk" import mojAlert -%}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}

{% set pageTitle = pageTitle + " - " + applicationName %}
{% set mainClasses = "app-container govuk-body" %}

{% block content %}
    <div class="govuk-grid-row">
      {% include "../partials/headerMenu.njk" %}

      <div class="govuk-grid-column-three-quarters">
        {% if presenter.isCohortUpdated %}
         {{ mojAlert(presenter.cohortUpdatedSuccessMessageArgs) }}
        {% endif %}
          {% if presenter.isLdcUpdated %}
        {{ mojAlert(presenter.ldcUpdatedSuccessMessageArgs) }}
        {% endif %}
        {% if isTransferredFromIM %}
          {{ govukInsetText(insetText) }}
        {% endif %}
      </div>
    </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <p class="govuk-body-m">{{ text.tableDescription | safe }}</p>
    </div>
  </div>

  {% if showAttendanceHistoryTable %}
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">
        {{ govukTable(groupTableArgs) }}
      </div>
    </div>
  {% endif %}

    <div class="govuk-grid-row">

    </div>

{% endblock %}

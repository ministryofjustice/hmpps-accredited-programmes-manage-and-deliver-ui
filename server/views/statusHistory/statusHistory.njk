{% extends "../partials/layout.njk" %}

{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{%- from "moj/components/timeline/macro.njk" import mojTimeline -%}
{%- from "govuk/components/tag/macro.njk" import govukTag -%}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/character-count/macro.njk" import govukCharacterCount %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{%- from "moj/components/sub-navigation/macro.njk" import mojSubNavigation -%}
{%- from "moj/components/alert/macro.njk" import mojAlert -%}

{% set pageTitle = applicationName + " - Home" %}
{% set mainClasses = "app-container govuk-body" %}

{% block referralSubNavigation %}
  <div class="govuk-width-container service-user-banner__sub-nav govuk-!-margin-bottom-0">
    {{ mojSubNavigation(presenter.getHorizontalSubNavArgs()) }}
  </div>
{% endblock %}

{% block main %}
  {% block content %}
     <main class="govuk-main-wrapper" id="main-content">
        <div class="govuk-grid-row">
          {% include "../partials/headerMenu.njk" %}
          <div class="govuk-grid-column-two-thirds">
          {% if errorSummary %}
            {{ govukErrorSummary(errorSummary) }}
          {% endif %}
          {% if successMessageSummary %}
            {{ mojAlert(successMessageSummary) }}
          {% endif %}
          {% if presenter.isCohortUpdated %}
            {{ mojAlert(presenter.cohortUpdatedSuccessMessageArgs) }}
          {% endif %}
          {% if presenter.isLdcUpdated %}
            {{ mojAlert(presenter.ldcUpdatedSuccessMessageArgs) }}
          {% endif %}
          {{ mojTimeline(statusHistoryTimelineOptions) }}
          </div>
        </div>
      </main>
 
    {% endblock %}
  {% endblock %}

{% extends "../partials/layout.njk" %}
{%- from "moj/components/timeline/macro.njk" import mojTimeline -%}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{%- from "moj/components/alert/macro.njk" import mojAlert -%}
{% set pageTitle = pageTitle + " - " + applicationName %}
{% set mainClasses = "app-container govuk-body" %}
{% block main %}
  {% block content %}
    <main class="govuk-main-wrapper" id="main-content">
        <div class="govuk-grid-row">
          {% include "../partials/headerMenu.njk" %}
          <div class="govuk-grid-column-two-thirds">
          {% if errorSummary %}
            {{ govukErrorSummary(errorSummary) }}
          {% endif %}
          {% if successMessageSummary %}
            {{ mojAlert(successMessageSummary) }}
          {% endif %}
          {% if presenter.isCohortUpdated %}
            {{ mojAlert(presenter.cohortUpdatedSuccessMessageArgs) }}
          {% endif %}
          {% if presenter.isLdcUpdated %}
            {{ mojAlert(presenter.ldcUpdatedSuccessMessageArgs) }}
          {% endif %}
          {{ mojTimeline(statusHistoryTimelineOptions) }}
          </div>
        </div>
    </main>
    {% endblock %}
  {% endblock %}

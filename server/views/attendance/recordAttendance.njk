{% extends "../partials/layout.njk" %}
{%- from "govuk/components/button/macro.njk" import govukButton %}
{%- from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% set pageTitle = applicationName + " - Home" %}
{% set mainClasses = "app-container govuk-body" %}

{% block content %}
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        {{ govukBackLink(backLinkArgs) }}
      </div>

      <div class="govuk-grid-column-two-thirds">
        {% if errorSummary !== null %}
          {{ govukErrorSummary(errorSummary) }}
        {% endif %}
        <span class="govuk-caption-l">{{text.headingCaption}}</span>
        <h1 class="govuk-heading-l">{{text.pageHeading}}</h1>
      </div>

      <div class="govuk-grid-column-two-thirds">
        <form method="post" novalidate class="add-another-form">
          <input type="hidden" name="_csrf" value="{{csrfToken}}">
          {% for radioArgs in radioArgsList %}
            {{ govukRadios(radioArgs) }}
          {% endfor %}
          {{ govukButton({ text: "Continue", preventDoubleClick: true }) }}
        </form>
      </div>
    </div>
{% endblock %}

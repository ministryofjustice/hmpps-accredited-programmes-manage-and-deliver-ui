{% extends "../../partials/layout.njk" %}

{%- from "moj/components/alert/macro.njk" import mojAlert -%}
{%- from "moj/components/sub-navigation/macro.njk" import mojSubNavigation -%}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{%- from "govuk/components/table/macro.njk" import govukTable -%}

{% set pageTitle = applicationName + " - Home" %}
{% set mainClasses = "app-container govuk-body" %}

{% block content %}

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
     {{ mojSubNavigation(serviceNavigationArgs) }}
    {% if successMessageArgs !== null %}
      {{ mojAlert(successMessageArgs) }}
    {% endif %}
    <span class="govuk-caption-xl">{{ text.headingCaptionText }}</span>
    <h1 class="govuk-heading-xl">{{ text.headingText }}</h1>
  </div>
</div>
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    {{ govukSummaryList(scheduleSummaryListArgs) }}
    {{ govukTable(scheduleSummaryTableArgs) }}
  </div>
</div>

{% endblock %}

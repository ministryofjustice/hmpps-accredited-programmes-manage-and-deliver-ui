{% extends "../partials/layout.njk" %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{%- from "moj/components/side-navigation/macro.njk" import mojSideNavigation -%}
{%- from "moj/components/alert/macro.njk" import mojAlert -%}
{%- from "govuk/macros/attributes.njk" import govukAttributes -%}

{% set pageTitle = pageTitle + " - " + applicationName %}
{% set mainClasses = "app-container govuk-body" %}

{% block main %}
  {% block content %}
    <main class="govuk-main-wrapper" id="main-content">
        <div class="govuk-grid-row">
          {% if showTopDataUnavailableMessage %}
            <div class="govuk-grid-column-full">
              {% set params = {
                attributes: { class: 'govuk-!-margin-bottom-4' },
                apiErrorMessageKey: 'ndeliusOrOasys'
              } %}
              {% include "../apiErrorMessages.njk" %}
            </div>
          {% endif %}
          {% include "../partials/headerMenu.njk" %}
          <div class="govuk-grid-column-three-quarters">
            {% if presenter.isCohortUpdated %}
            {{ mojAlert(presenter.cohortUpdatedSuccessMessageArgs) }}
            {% endif %}
            {% if presenter.isLdcUpdated %}
            {{ mojAlert(presenter.ldcUpdatedSuccessMessageArgs) }}
            {% endif %}
            <h2 class="govuk-heading-l">Referral summary</h2>
            {{ govukSummaryList(presenter.referralSummary) }}
          </div>
        </div>


      <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
          <hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible">
        </div>
      </div>
      <div class="govuk-grid-row">

        <div class="govuk-grid-column-one-third">

          {{ mojSideNavigation(presenter.getVerticalSubNavArgs()) }}

        </div>
        <div class="govuk-grid-column-two-thirds">

          {% if presenter.subNavValue == 'offenceHistory' %}
            <div>
              {% include "./offenceHistory.njk" %}
            </div>
          {% elif presenter.subNavValue == 'sentenceInformation' %}
            <div>
              {% include "./sentenceInformation.njk" %}
            </div>
          {% elif presenter.subNavValue == 'location' %}
            <div>
              {% include "./location.njk" %}
            </div>
          {% else %}
            {% include "./personalDetails.njk" %}
          {% endif %}
        </div>
      </div>
    </main>
  {% endblock %}
{% endblock %}

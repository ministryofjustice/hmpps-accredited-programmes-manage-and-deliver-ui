{% extends "../partials/layout.njk" %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/character-count/macro.njk" import govukCharacterCount %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% set pageTitle = pageTitle + " - " + applicationName %}
{% set mainClasses = "app-container govuk-body" %}

{% block main %}
  {% block content %}
    <div class="govuk-width-container">
      <nav aria-label="Back">
        {{ govukBackLink(backLinkArgs) }}
      </nav>
      <main class="govuk-main-wrapper" id="main-content">
        <div class="govuk-grid-row">
          <div class="govuk-grid-column-two-thirds">
            {% if errorSummary !== null %}
              {{ govukErrorSummary(errorSummary) }}
            {% endif %}
            <form method="post" novalidate>
              <input type="hidden" name="_csrf" value="{{csrfToken}}">
              {% set cannotAttendLocationsTextAreaHtml %}
                {{ govukCharacterCount(cannotAttendLocationsTextAreaArgs) }}
              {% endset %}
              {{ govukRadios(radioArgs(cannotAttendLocationsTextAreaHtml)) }}
              <div class="govuk-button-group">
                {{ govukButton({ text: "Submit", preventDoubleClick: true }) }}
                <a class="govuk-link" href="{{ cancelLink }}">Cancel</a>
              </div>
            </form>
          </div>
        </div>
      </main>
    </div>
  {% endblock %}
{% endblock %}

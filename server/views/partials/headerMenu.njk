{%- from "moj/components/button-menu/macro.njk" import mojButtonMenu -%}
<div class="govuk-grid-column-two-thirds">
    <span class="govuk-caption-xl">Building Choices: moderate intensity</span>
    <h1 class="govuk-heading-xl">{{ presenter.headingText or presenter.title or presenter.heading or presenter.pageTitle }}</h1>
</div>
<div class="govuk-grid-column-one-third">
    <div class="moj-button-group moj-button-group--inline header-menu-button">
        {% if presenter.showButtonMenu() %}
          {{ mojButtonMenu(presenter.getButtonMenu()) }}
        {% endif %}
    </div>
</div>
{% include "./subHeaderMenu.njk" %}{%- from "moj/components/button-menu/macro.njk" import mojButtonMenu -%}
{% set navTwoHeaderMenu = subHeaderMenu or presenter.subHeaderMenu %}
<div class="govuk-grid-column-two-thirds">
    <span class="govuk-caption-xl">{{ navTwoHeaderMenu.caption }}</span>
    <h1 class="govuk-heading-xl">{{ navTwoHeaderMenu.heading }}</h1>
</div>
<div class="govuk-grid-column-one-third">
    <div class="moj-button-group moj-button-group--inline header-menu-button">
        {% if navTwoHeaderMenu.showButtonMenu %}
          {{ mojButtonMenu(navTwoHeaderMenu.buttonMenu) }}
        {% endif %}
    </div>
</div>
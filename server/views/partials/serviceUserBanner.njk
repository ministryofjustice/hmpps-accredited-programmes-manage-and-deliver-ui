{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}
{%- from "moj/components/sub-navigation/macro.njk" import mojSubNavigation -%}

{{ govukPhaseBanner({
  tag: {
    text: "Prototype"
  },
  html: 'This is a new service - your <a class="govuk-link" href="#">feedback</a> will help us improve it.'
}) }}

<section class="key-details-bar" aria-label="Key details">
  <div class="key-details-bar__key-details govuk-width-container govuk-body">
    <div class="prisoner-info">
      <div class="key-details-bar__top-block">
        <span class="govuk-visually-hidden">Name:</span>
        <span class="key-details-bar__name">
          <strong>{{ serviceUserBannerPresenter.name }}</strong>
        </span>
      </div>
      <div class="key-details-bar__bottom-block">
        <span class="govuk-body govuk-!-margin-right-2">
          <strong>CRN: </strong>{{ serviceUserBannerPresenter.crn }}</span> |
        <span class="govuk-body govuk-!-margin-right-2 govuk-!-margin-left-2">
          <strong>Date of birth: </strong>{{ serviceUserBannerPresenter.dateOfBirth }}</span>
      </div>
    </div>
  </div>
</section>
{% set horizontalSubNavArgs = null %}
{% if presenter and presenter.getHorizontalSubNavArgs %}
  {% set horizontalSubNavArgs = presenter.getHorizontalSubNavArgs() %}
{% endif %}
{% if horizontalSubNavArgs %}
<div class="govuk-width-container service-user-banner__sub-nav govuk-!-margin-bottom-0">
  {{ mojSubNavigation({
    label: "Sub navigation",
    classes: horizontalSubNavArgs.classes,
    items: horizontalSubNavArgs.items
  }) }}
</div>
{% endif %}